			<key>NSMenuItem</key>
			<dict>
				<key>default</key>
				<string>Read in CueRecord</string>
			</dict>
			<key>NSMessage</key>
			<string>readInCueRecord</string>
			<key>NSPortName</key>
			<string>CueRecord</string>
			<key>NSSendTypes</key>
			<array>
				<string>public.utf8-plain-text</string>
			</array>
		</dict>
	</array>
	<key>UTImportedTypeDeclarations</key>
