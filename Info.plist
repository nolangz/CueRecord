			</array>
			<key>UTTypeDescription</key>
			<string>Legacy CueRecord Document</string>
			<key>UTTypeIdentifier</key>
			<string>com.nolanlai.cueshot.document</string>
			<key>UTTypeTagSpecification</key>
			<dict>
